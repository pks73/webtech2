$file = fopen("contact.dat", "r");

echo "<table border='1'>";
echo "<tr>
        <th>Sr No</th>
        <th>Name</th>
        <th>Residence No</th>
        <th>Mobile No</th>
        <th>Address</th>
      </tr>";

while(($line = fgets($file)) !== false)
{
    $data = explode(",", $line);
    echo "<tr>";
    foreach($data as $value)
    {
        echo "<td>" . trim($value) . "</td>";
    }
    echo "</tr>";
}

echo "</table>";

fclose($file);
?>

